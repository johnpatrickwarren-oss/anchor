{
  "name": "@anchor/core",
  "version": "0.0.1",
  "type": "module",
  "description": "Anchor role engine + runtime-adapter seam — the discipline+memory layer that runs on a commodity agent runtime (Agent SDK / Atomic / Claude Code).",
  "license": "Apache-2.0",
  "engines": { "node": ">=24" },
  "files": ["dist"],
  "exports": { ".": "./src/index.ts" },
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": { "types": "./dist/index.d.ts", "default": "./dist/index.js" }
    }
  },
  "scripts": {
    "test": "node --test test/*.test.ts",
    "build": "tsc -p tsconfig.build.json && node ../../scripts/rewrite-dts-ext.mjs dist",
    "prepack": "pnpm run build"
  }
}
