{
  "name": "@anchor/runtime-agent-sdk",
  "version": "0.0.1",
  "type": "module",
  "description": "RuntimeAdapter for @anchor/core backed by the Claude Agent SDK (query()).",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=24"
  },
  "files": ["dist"],
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": { "types": "./dist/index.d.ts", "default": "./dist/index.js" }
    }
  },
  "dependencies": {
    "@anchor/core": "workspace:*",
    "@anthropic-ai/claude-agent-sdk": "^0.3.156"
  },
  "scripts": {
    "test": "node --test test/*.test.ts",
    "smoke": "node smoke/smoke.ts",
    "smoke:mock": "node smoke/smoke.ts --mock",
    "build": "tsc -p tsconfig.build.json && node ../../scripts/rewrite-dts-ext.mjs dist",
    "prepack": "pnpm run build"
  }
}
