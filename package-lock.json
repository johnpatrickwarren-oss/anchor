{
  "name": "anchor-workspace",
  "version": "0.0.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "anchor-workspace",
      "version": "0.0.0",
      "license": "Apache-2.0",
      "workspaces": [
        "packages/*"
      ],
      "engines": {
        "node": ">=24"
      }
    },
    "node_modules/@anchor/cli": {
      "resolved": "packages/cli",
      "link": true
    },
    "node_modules/@anchor/core": {
      "resolved": "packages/core",
      "link": true
    },
    "node_modules/@anchor/runtime-agent-sdk": {
      "resolved": "packages/runtime-agent-sdk",
      "link": true
    },
    "packages/cli": {
      "name": "@anchor/cli",
      "version": "0.0.1",
      "license": "Apache-2.0",
      "dependencies": {
        "@anchor/core": "*",
        "@anchor/runtime-agent-sdk": "*"
      },
      "bin": {
        "anchor": "src/cli.ts"
      },
      "engines": {
        "node": ">=24"
      }
    },
    "packages/core": {
      "name": "@anchor/core",
      "version": "0.0.1",
      "license": "Apache-2.0",
      "engines": {
        "node": ">=24"
      }
    },
    "packages/runtime-agent-sdk": {
      "name": "@anchor/runtime-agent-sdk",
      "version": "0.0.1",
      "license": "Apache-2.0",
      "engines": {
        "node": ">=24"
      },
      "peerDependencies": {
        "@anthropic-ai/claude-agent-sdk": ">=0.1.0"
      },
      "peerDependenciesMeta": {
        "@anthropic-ai/claude-agent-sdk": {
          "optional": true
        }
      }
    }
  }
}
